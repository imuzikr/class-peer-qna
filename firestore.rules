rules_version = '2';

// =============================================================
// Firestore 보안 규칙 — class-peer-qna
// -------------------------------------------------------------
// 원칙
//  · 로그인하지 않으면 아무것도 못 읽고/못 씀 (기본 거부)
//  · 질문 게시판(questions·answers·notices·keywords)은 전체 공유
//  · 공부방(반)의 모든 자산(보드·카드·과일·누가기록·KWL·입장코드)은
//    그 반을 개설한 교사(classes.createdBy)에게 귀속.
//    최고 관리자(role=admin 또는 부트스트랩 이메일)만 전체 접근.
//  · 역할(role)은 클라이언트가 스스로 못 바꿈 — functions/setUserRole로만
// 배포:  firebase deploy --only firestore:rules
// =============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function userRole() { return request.auth.token.get('role', ''); }

    // 초기(최고) 관리자 — 역할 클레임이 없어도 관리자. email_verified 필수.
    function isInitialAdmin() {
      return signedIn() && request.auth.token.email == 'iseoul72@gmail.com'
             && request.auth.token.email_verified == true;
    }
    // 최고 관리자 — 모든 반의 데이터·기능에 접근(반 소유 제한의 예외)
    function isAdmin() {
      return signedIn() && (userRole() == 'admin' || isInitialAdmin());
    }
    // 교사(최고 관리자 포함) — 교사용 기능 접근 관문
    function isTeacher() {
      return signedIn() &&
        (userRole() == 'teacher' || userRole() == 'admin' || isInitialAdmin());
    }
    function changedOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // ── 반 소유권 헬퍼 ────────────────────────────────────────
    // 반 개설자 uid / 그 반의 소유 교사인지 / 소속 멤버인지.
    function classOwnerUid(cId) {
      return get(/databases/$(database)/documents/classes/$(cId)).data.createdBy;
    }
    function ownsClass(cId) {
      // isTeacher()가 false면 &&에서 단락되어 get을 수행하지 않음(학생 비용 없음)
      return isTeacher() && classOwnerUid(cId) == uid();
    }
    function isClassMember(cId) {
      return exists(/databases/$(database)/documents/memberships/$(uid() + '_' + cId));
    }

    // ── 공부방 보드 헬퍼 ──────────────────────────────────────
    function studyBoardClassId(bId) {
      return get(/databases/$(database)/documents/studyBoards/$(bId)).data.classId;
    }
    function ownsBoard(bId) {
      return ownsClass(studyBoardClassId(bId));
    }
    function isBoardClassMember(bId) {
      return isClassMember(studyBoardClassId(bId));
    }
    function isBoardLocked(bId) {
      return get(/databases/$(database)/documents/studyBoards/$(bId)).data.editMode == 'locked';
    }
    // '선생님 보드'(type: notice) — 교사 전용 쓰기. 학생은 읽기만(첨부 다운로드 포함).
    function isNoticeBoard(bId) {
      return get(/databases/$(database)/documents/studyBoards/$(bId)).data.type == 'notice';
    }
    // 모둠 활동 보드 여부 / '함께 보기' 여부
    function isGroupBoard(bId) {
      return get(/databases/$(database)/documents/studyBoards/$(bId)).data.get('activityType', 'individual') == 'group';
    }
    function isSharedBoard(bId) {
      return get(/databases/$(database)/documents/studyBoards/$(bId)).data.viewMode == 'shared';
    }
    // 이 카드가 모둠 카드이고 내가 그 모둠의 구성원인지
    function isMyGroupCard() {
      return resource.data.get('memberUids', []).hasAny([uid()]);
    }

    // ── 사용자 프로필 ─────────────────────────────────────────
    // 실명·이메일 등 식별 정보(PII)가 여기에만 있으므로, 읽기는 본인+교사로 제한.
    // (질문 게시판은 전체 공유라 교사가 타 반 학생 실명도 확인해야 하므로 교사 전체 허용)
    match /users/{userId} {
      allow read: if signedIn() && (userId == uid() || isTeacher());
      // 본인만 생성, 가입 시 role은 'student' 고정 (스스로 승격 불가)
      allow create: if signedIn() && userId == uid()
                    && request.resource.data.role == 'student';
      // 본인 자가수정: 닉네임(displayName)·실명·학번은 불가(교사만 수정).
      //   → 이메일·아바타·알림토큰·선생님 가입신청만 허용.
      // 교사/관리자는 학생 프로필 전체 관리 가능.
      allow update: if (signedIn() && userId == uid()
                        && changedOnly(['email','emoji','fcmTokens','requestedRole']))
                    || isTeacher();
      // 탈퇴(계정 삭제): 관리자는 누구나, 교사는 '학생' 계정만.
      allow delete: if isAdmin()
                    || (isTeacher()
                        && resource.data.role == 'student'
                        && resource.data.get('email','') != 'iseoul72@gmail.com');

      match /notifications/{nId} {
        allow read, write: if signedIn() && userId == uid();
      }
    }

    // ── 질문 (전체 공유) ──────────────────────────────────────
    match /questions/{qId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.authorId == uid()
                    && request.resource.data.answerCount == 0
                    && request.resource.data.meTooIds == []
                    && request.resource.data.resolved == false;
      allow update: if signedIn() && (
        (resource.data.authorId == uid()
          && changedOnly(['title','content','keyword','imageUrl','images',
                          'resolved','reflectionPending','understoodAnswerId','reflection']))
        || isTeacher()
        || (changedOnly(['meTooIds'])
            && resource.data.authorId != uid()
            && request.resource.data.meTooIds.toSet()
                 .difference(resource.data.meTooIds.toSet()).hasOnly([uid()])
            && resource.data.meTooIds.toSet()
                 .difference(request.resource.data.meTooIds.toSet()).hasOnly([uid()]))
      );
      allow delete: if signedIn() && (resource.data.authorId == uid() || isTeacher());

      match /answers/{aId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.authorId == uid();
        allow update: if signedIn() && (
          (resource.data.authorId == uid()
            && changedOnly(['content','imageUrl','images']))
          || isTeacher()
          || (changedOnly(['understood'])
              && get(/databases/$(database)/documents/questions/$(qId)).data.authorId == uid())
        );
        allow delete: if signedIn() && (resource.data.authorId == uid() || isTeacher());
      }
    }

    // ── 공지 — 교사만 작성 (전체 공유) ────────────────────────
    match /notices/{nId} {
      allow read: if signedIn();
      allow write: if isTeacher();
    }

    // ── 키워드 — 읽기 모두, 생성/수정/삭제는 교사 (전체 공유) ──
    match /keywords/{kId} {
      allow read: if signedIn();
      allow create, update, delete: if isTeacher();
    }

    // ── 반(클래스) ────────────────────────────────────────────
    //  · 이름은 공개 메타데이터(입장 코드 확인 등) → 읽기는 로그인 사용자.
    //    교사 화면은 본인 개설 반만 클라이언트에서 필터링해 표시.
    //  · 생성: 교사 본인이 개설자. 수정/삭제: 개설자 또는 최고 관리자만.
    match /classes/{cId} {
      allow read: if signedIn();
      allow create: if isTeacher() && request.resource.data.createdBy == uid();
      allow update, delete: if isAdmin()
                            || (isTeacher() && resource.data.createdBy == uid());
    }

    // ── 입장 코드 — 문서 ID가 코드 자체. 코드 소유 교사만 관리. ──
    //  · get : 정확한 코드를 아는 사람만 1건 읽기(학생 입장 시)
    //  · list: 최고 관리자 또는 코드 개설 교사만(쿼리를 createdBy로 제한해야 함)
    //  · 생성/삭제: 최고 관리자 또는 개설 교사
    match /joinCodes/{code} {
      allow get: if signedIn();
      allow list: if isAdmin() || resource.data.createdBy == uid();
      allow create: if isAdmin()
                    || (isTeacher() && request.resource.data.createdBy == uid());
      allow update, delete: if isAdmin()
                            || (isTeacher() && resource.data.createdBy == uid());
    }

    // ── 소속(멤버십) — 본인 것 + 그 반 소유 교사/관리자만. ──
    match /memberships/{mId} {
      allow read: if signedIn() && (
        resource.data.uid == uid() || isAdmin() || ownsClass(resource.data.classId)
      );
      allow create: if signedIn()
                    && request.resource.data.uid == uid()
                    && mId == (uid() + '_' + request.resource.data.classId)
                    && get(/databases/$(database)/documents/joinCodes/$(request.resource.data.code))
                         .data.classId == request.resource.data.classId
                    && get(/databases/$(database)/documents/joinCodes/$(request.resource.data.code))
                         .data.expiresAt > request.time;
      allow delete: if signedIn() && (
        resource.data.uid == uid() || isAdmin() || ownsClass(resource.data.classId)
      );
    }

    // ── 학생 보상(과일) — 반 소유 교사/관리자만 쓰기, 읽기는 소속 학생도. ──
    //  · 문서 ID = `{classId}_{uid}`. 문서엔 uid·과일 수·이름표만(공부방은 실명 공간).
    //  · 20개마다 별(⭐)로 접어 표시 — 상한 100(별 5개).
    match /rewards/{rId} {
      allow read: if isAdmin()
                  || ownsClass(resource.data.classId)
                  || isClassMember(resource.data.classId);
      allow create, update: if (isAdmin() || ownsClass(request.resource.data.classId))
                   && request.resource.data.count is int
                   && request.resource.data.count >= 0
                   && request.resource.data.count <= 100
                   && rId == (request.resource.data.classId + '_' + request.resource.data.uid);
      allow delete: if isAdmin() || ownsClass(resource.data.classId);
    }

    // ── 누가기록(학생 관찰 메모) — 반 소유 교사/관리자 전용 (학생 열람 불가) ──
    match /studentNotes/{noteId} {
      allow read: if isAdmin()
                  || (resource.data.classId != null && ownsClass(resource.data.classId));
      allow create: if (isAdmin()
                        || (request.resource.data.classId != null
                            && ownsClass(request.resource.data.classId)))
                    && request.resource.data.teacherId == uid()
                    && request.resource.data.studentUid is string;
      allow update, delete: if isAdmin()
                            || (resource.data.classId != null && ownsClass(resource.data.classId));
    }

    // ── 공부방 보드 — 읽기는 로그인 사용자(메타데이터), 쓰기는 반 소유 교사/관리자 ──
    match /studyBoards/{bId} {
      allow read: if signedIn();
      allow create: if isAdmin()
                    || (isTeacher() && ownsClass(request.resource.data.classId));
      allow update, delete: if isAdmin() || ownsClass(resource.data.classId);

      match /cards/{cardId} {
        // 읽기 — 본인 카드(0 get, 최우선) / 관리자 / 반 소유 교사 / 반 멤버.
        // 단, 모둠 보드가 '자기 모둠만'(private)일 때 반 멤버는 자기 모둠
        // 카드만 읽을 수 있음(memberUids array-contains 쿼리로 접근).
        // '함께 보기'(shared)면 다른 모둠 카드도 읽기 가능(수정은 불가).
        allow read: if signedIn() && (
          resource.data.authorId == uid()
          || isAdmin()
          || ownsBoard(bId)
          || (isBoardClassMember(bId)
              && (
                   !isGroupBoard(bId)
                   || isSharedBoard(bId)
                   || isMyGroupCard()
                 ))
        );
        // 생성 — 관리자/소유 교사는 자유(모둠 카드도 교사가 생성).
        //   학생은 (문서ID=uid) + 반 멤버 + 잠금 아님 + notice 아님 + 모둠 보드 아님.
        allow create: if signedIn()
                      && request.resource.data.authorId == uid()
                      && (
                           isAdmin()
                           || ownsBoard(bId)
                           || (cardId == uid()
                               && isBoardClassMember(bId)
                               && !isBoardLocked(bId)
                               && !isNoticeBoard(bId)
                               && !isGroupBoard(bId))
                         );
        // 수정 — 관리자/소유 교사, 본인 카드(작성자 불변·멤버·잠금 아님·notice 아님),
        //   또는 내 모둠 카드(내용 필드만 — 모둠 명단·대표·작성자는 교사만 변경).
        allow update: if signedIn() && (
          isAdmin()
          || ownsBoard(bId)
          || (cardId == uid()
              && request.resource.data.authorId == resource.data.authorId
              && isBoardClassMember(bId)
              && !isBoardLocked(bId)
              && !isNoticeBoard(bId))
          || (isMyGroupCard()
              && isBoardClassMember(bId)
              && !isBoardLocked(bId)
              && changedOnly(['title','content','imageUrl','attachments','updatedAt']))
        );
        // 삭제 — 관리자/소유 교사, 또는 본인 카드(멤버·notice 아님).
        //   모둠 카드는 학생 삭제 불가(문서ID가 uid가 아니므로 자동 차단).
        allow delete: if signedIn() && (
          isAdmin()
          || ownsBoard(bId)
          || (cardId == uid() && isBoardClassMember(bId) && !isNoticeBoard(bId))
        );
      }
    }

    // ── KWL — 개인 성찰. 본인 + 반 소유 교사/관리자만. ──
    match /kwl/{kwlId} {
      allow read: if signedIn() && (
        resource.data.userId == uid() || isAdmin() || ownsClass(resource.data.classId)
      );
      allow create: if signedIn() && request.resource.data.userId == uid();
      allow update, delete: if signedIn() && (
        resource.data.userId == uid() || isAdmin() || ownsClass(resource.data.classId)
      );
    }

    // ── 컬렉션 그룹 쿼리 규칙 ─────────────────────────────────
    // collectionGroup() 쿼리는 {path=**} 그룹 규칙이 없으면 무조건 거부됨.
    // · answers: 질문 게시판은 전체 공유라 로그인 사용자 읽기(경로 규칙과 동일 노출)
    // · cards  : 본인 카드(학생 리포트 '내 카드') / 내 모둠 카드 / 최고 관리자만.
    //   교사에게는 열지 않음 — 반(보드) 격리 유지. 쓰기는 여기 없음(경로 규칙 적용).
    match /{path=**}/answers/{aId} {
      allow read: if signedIn();
    }
    match /{path=**}/cards/{cardId} {
      allow read: if signedIn() && (
        resource.data.authorId == uid()
        || isAdmin()
        || resource.data.get('memberUids', []).hasAny([uid()])
      );
    }

    // ── 통계/시스템 — Cloud Functions(admin SDK)만 쓰기 ──
    // 주간 질문대장/답변왕만 로그인 전 랜딩 화면 노출을 위해 공개 읽기 허용.
    match /stats/weeklyQuestioners {
      allow read: if true;
      allow write: if false;
    }
    match /stats/weeklyAnswerers {
      allow read: if true;
      allow write: if false;
    }
    match /stats/{doc} {
      allow read: if isTeacher();
      allow write: if false;
    }
  }
}
