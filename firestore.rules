rules_version = '2';

// =============================================================
// Firestore 보안 규칙 — class-peer-qna
// -------------------------------------------------------------
// 원칙
//  · 로그인하지 않으면 아무것도 못 읽고/못 씀 (기본 거부)
//  · 내 글은 나만, 남의 글은 못 고침 (작성자 == request.auth.uid)
//  · 교사/관리자(역할 클레임 또는 초기 관리자 이메일)는 관리 권한
//  · 역할(role)은 클라이언트가 스스로 못 바꿈 — functions/setUserRole로만
// 배포:  firebase deploy --only firestore:rules
// =============================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    // role 커스텀 클레임이 없는 사용자(일반 학생)도 안전하게 평가되도록
    // 없는 키를 직접 읽지 않고 기본값('')과 함께 꺼낸다.
    // (직접 request.auth.token.role를 읽으면 "Property role is undefined" 오류 → 거부)
    function userRole() { return request.auth.token.get('role', ''); }

    // 초기 관리자 — 아직 역할 클레임이 없어도 관리자 권한(부트스트랩)
    // email_verified 필수: 소유가 확인된 계정만 인정 (functions/setUserRole과 동일 기준)
    function isInitialAdmin() {
      return signedIn() && request.auth.token.email == 'iseoul72@gmail.com'
             && request.auth.token.email_verified == true;
    }
    function isTeacher() {
      return signedIn() &&
        (userRole() == 'teacher' || userRole() == 'admin' || isInitialAdmin());
    }
    function isAdmin() {
      return signedIn() && (userRole() == 'admin' || isInitialAdmin());
    }
    // 변경된 필드가 주어진 목록뿐인지 확인
    function changedOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    // ── 공부방 카드 격리·잠금 헬퍼 ──
    // 카드가 속한 보드의 반(classId), 그 반의 멤버 여부, 보드 잠금 여부.
    function studyBoardClassId(bId) {
      return get(/databases/$(database)/documents/studyBoards/$(bId)).data.classId;
    }
    function isBoardClassMember(bId) {
      return exists(/databases/$(database)/documents/memberships/$(uid() + '_' + studyBoardClassId(bId)));
    }
    function isBoardLocked(bId) {
      return get(/databases/$(database)/documents/studyBoards/$(bId)).data.editMode == 'locked';
    }

    // ── 사용자 프로필 ─────────────────────────────────────────
    // 실명·이메일 등 식별 정보(PII)가 여기에만 있으므로, 읽기는 본인+교사로
    // 제한합니다. (게시판 피드는 questions의 익명 닉네임만 쓰고 users는 안 읽음)
    match /users/{userId} {
      allow read: if signedIn() && (userId == uid() || isTeacher());
      // 본인만 생성, 가입 시 role은 'student' 고정 (스스로 승격 불가)
      allow create: if signedIn() && userId == uid()
                    && request.resource.data.role == 'student';
      // 본인은 프로필 일부 + 선생님 가입 신청(requestedRole)만 수정,
      // 교사/관리자는 학생 프로필 관리 가능
      allow update: if (signedIn() && userId == uid()
                        && changedOnly(['email','realName','displayName','emoji','studentId','fcmTokens','requestedRole']))
                    || isTeacher();
      // 탈퇴(계정 삭제): 관리자는 누구나, 교사는 '학생' 계정만.
      //  · 부트스트랩 최고 관리자는 users.role이 'student'로 남아 있을 수 있으므로
      //    이메일로도 명시 차단(교사가 최고 관리자를 삭제하지 못하게).
      allow delete: if isAdmin()
                    || (isTeacher()
                        && resource.data.role == 'student'
                        && resource.data.get('email','') != 'iseoul72@gmail.com');

      // 인앱 알림 — 본인만
      match /notifications/{nId} {
        allow read, write: if signedIn() && userId == uid();
      }
    }

    // ── 질문 ──────────────────────────────────────────────────
    match /questions/{qId} {
      allow read: if signedIn();
      // 생성 시 카운터·상태는 초깃값 고정 (통계·랭킹 위조 방지)
      allow create: if signedIn() && request.resource.data.authorId == uid()
                    && request.resource.data.answerCount == 0
                    && request.resource.data.meTooIds == []
                    && request.resource.data.resolved == false;
      allow update: if signedIn() && (
        // 작성자: 내용 수정 + 해결/인사이트만 — 필드 화이트리스트로
        // authorId/authorName/authorEmoji(신원)와 answerCount는 변경 불가(사칭 방지)
        (resource.data.authorId == uid()
          && changedOnly(['title','content','keyword','imageUrl','images',
                          'resolved','reflectionPending','understoodAnswerId','reflection']))
        || isTeacher()
        // '궁금해요' 토글 — 내 uid만 추가/삭제 가능(남의 목록 위조 방지)
        || (changedOnly(['meTooIds'])
            && request.resource.data.meTooIds.toSet()
                 .difference(resource.data.meTooIds.toSet()).hasOnly([uid()])
            && resource.data.meTooIds.toSet()
                 .difference(request.resource.data.meTooIds.toSet()).hasOnly([uid()]))
        // answerCount는 Cloud Functions(admin SDK, 규칙 미적용)만 집계 — 클라 변경 차단
      );
      allow delete: if signedIn() && (resource.data.authorId == uid() || isTeacher());

      // ── 답변(하위 컬렉션) ──
      match /answers/{aId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.authorId == uid();
        allow update: if signedIn() && (
          // 작성자: 내용 관련 필드만 — 신원(authorId 등) 변경 불가
          (resource.data.authorId == uid()
            && changedOnly(['content','imageUrl','images']))
          || isTeacher()
          // 질문 작성자가 '이해됐어요' 표시 — understood 필드만 변경 허용
          || (changedOnly(['understood'])
              && get(/databases/$(database)/documents/questions/$(qId)).data.authorId == uid())
        );
        allow delete: if signedIn() && (resource.data.authorId == uid() || isTeacher());
      }
    }

    // ── 공지 — 교사만 작성 ────────────────────────────────────
    match /notices/{nId} {
      allow read: if signedIn();
      allow write: if isTeacher();
    }

    // ── 키워드 — 읽기 모두, 생성/수정/삭제는 교사만 (스팸·비용 차단) ──
    //   최초 기본 키워드 시드도 교사 최초 로그인 때 수행됩니다.
    match /keywords/{kId} {
      allow read: if signedIn();
      allow create, update, delete: if isTeacher();
    }

    // ── 반(클래스) — 이름은 비밀 아님(읽기 허용). 입장 코드는 여기 없음. ──
    match /classes/{cId} {
      allow read: if signedIn();
      allow write: if isTeacher();
    }

    // ── 입장 코드 — 문서 ID가 코드 자체. 열거(list) 차단이 핵심. ──
    //  · get : 정확한 코드를 아는 사람만 1건 읽기(학생 입장 시)
    //  · list: 교사만 — 일반 사용자는 코드들을 긁어모을 수 없음
    //  · write: 교사만 발급/재발급/삭제
    match /joinCodes/{code} {
      allow get: if signedIn();
      allow list: if isTeacher();
      allow write: if isTeacher();
    }

    // ── 소속(멤버십) — 기기 바꿔도 유지. 본인 것만 보고/만들고/지움. ──
    //  생성 시 입장 코드를 서버에서 검증합니다:
    //  · 클라이언트가 code 필드를 함께 보내면, 그 코드 문서(joinCodes/{code})가
    //    해당 반의 것이고 아직 만료 전(expiresAt > 지금)인지 확인
    //  · 문서 ID가 정확히 `{내uid}_{classId}` 형식인지도 강제
    //  → SDK 직접 호출로 코드 없이/만료된 코드로 아무 반에나 가입하는 것 차단
    match /memberships/{mId} {
      allow read: if signedIn() && (resource.data.uid == uid() || isTeacher());
      allow create: if signedIn()
                    && request.resource.data.uid == uid()
                    && mId == (uid() + '_' + request.resource.data.classId)
                    && get(/databases/$(database)/documents/joinCodes/$(request.resource.data.code))
                         .data.classId == request.resource.data.classId
                    && get(/databases/$(database)/documents/joinCodes/$(request.resource.data.code))
                         .data.expiresAt > request.time;
      allow delete: if signedIn() && (resource.data.uid == uid() || isTeacher());
    }

    // ── 공부방 보드 — 교사 관리, 카드는 학생 본인(문서ID = uid) ──
    match /studyBoards/{bId} {
      allow read: if signedIn();
      allow write: if isTeacher();

      match /cards/{cardId} {
        // 카드(학생 제출물) 읽기 — 반 격리:
        //  · 교사: 전체
        //  · 본인 카드: 항상
        //  · 그 외: 그 보드가 속한 반의 멤버만 (다른 반 학생 열람 차단)
        allow read: if signedIn() && (
          isTeacher()
          || resource.data.authorId == uid()
          || isBoardClassMember(bId)
        );
        // 생성 — 학생은 (문서ID=uid) + 그 보드 반의 멤버 + 보드가 잠금 아님.
        //   교사는 보드당 여러 카드 허용(자동 ID). authorId는 본인이어야 함.
        allow create: if signedIn()
                      && request.resource.data.authorId == uid()
                      && (
                           isTeacher()
                           || (cardId == uid()
                               && isBoardClassMember(bId)
                               && !isBoardLocked(bId))
                         );
        // 수정 — 본인 카드 + 작성자 불변 + 반 멤버 + 보드 잠금 아님. 교사는 전체.
        allow update: if signedIn() && (
          isTeacher()
          || (cardId == uid()
              && request.resource.data.authorId == resource.data.authorId
              && isBoardClassMember(bId)
              && !isBoardLocked(bId))
        );
        // 삭제 — 본인 카드 + 반 멤버. 교사는 전체.
        allow delete: if signedIn() && (
          isTeacher()
          || (cardId == uid() && isBoardClassMember(bId))
        );
      }
    }

    // ── KWL — 개인 성찰. 읽기는 본인 + 교사만(다른 학생은 못 봄) ──
    match /kwl/{kwlId} {
      allow read: if signedIn() && (resource.data.userId == uid() || isTeacher());
      allow create: if signedIn() && request.resource.data.userId == uid();
      allow update, delete: if signedIn() && (resource.data.userId == uid() || isTeacher());
    }

    // ── 통계/시스템 — Cloud Functions(admin SDK)만 쓰기 ──
    match /stats/{doc} {
      allow read: if isTeacher();
      allow write: if false;
    }
  }
}
